# =============================================================================
# AquaMinerals API — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente.
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
API_PREFIX=/api/v1
APP_NAME=AquaMinerals API
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aquaminerals?schema=public"

# -----------------------------------------------------------------------------
# CORS (Frontend React — Vite default port)
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# JWT (reservado para fases futuras — autenticação)
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-me-in-production-use-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Logs (Pino)
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Swagger / OpenAPI
# -----------------------------------------------------------------------------
SWAGGER_ENABLED=true
SWAGGER_ROUTE=/docs
