NODE_ENV=production
PORT=3333
HOST=0.0.0.0
API_PREFIX=/api/v1
APP_NAME=AquaMinerals API
APP_VERSION=1.0.0
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aquaminerals?schema=public"
CORS_ORIGIN=https://aquaminerals.io
JWT_SECRET=replace-with-strong-production-secret
JWT_REFRESH_SECRET=replace-with-strong-production-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
LOG_LEVEL=info
SWAGGER_ENABLED=false
SWAGGER_ROUTE=/docs
